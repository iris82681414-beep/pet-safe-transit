<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sky.logistics.mapper.LogisticsUserMapper">

    <sql id="UserColumns">
        id,
        username,
        password_hash AS passwordHash,
        name,
        role,
        phone,
        created_at AS createdAt,
        updated_at AS updatedAt
    </sql>

    <sql id="UserWhere">
        <where>
            <if test="role != null and role != ''">
                AND role = #{role}
            </if>
            <if test="keyword != null and keyword != ''">
                AND (
                    username ILIKE CONCAT('%', #{keyword}, '%')
                    OR name ILIKE CONCAT('%', #{keyword}, '%')
                    OR phone ILIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
        </where>
    </sql>

    <select id="findPage" resultType="com.sky.logistics.entity.LogisticsUser">
        SELECT
            <include refid="UserColumns"/>
        FROM users
        <include refid="UserWhere"/>
        ORDER BY created_at DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM users
        <include refid="UserWhere"/>
    </select>

    <select id="findByUsername" resultType="com.sky.logistics.entity.LogisticsUser">
        SELECT
            <include refid="UserColumns"/>
        FROM users
        WHERE username = #{username}
    </select>

    <select id="findById" resultType="com.sky.logistics.entity.LogisticsUser">
        SELECT
            <include refid="UserColumns"/>
        FROM users
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.sky.logistics.entity.LogisticsUser">
        INSERT INTO users (
            id,
            username,
            password_hash,
            name,
            role,
            phone,
            created_at,
            updated_at
        ) VALUES (
            #{id},
            #{username},
            #{passwordHash},
            #{name},
            #{role},
            #{phone},
            now(),
            now()
        )
    </insert>

    <update id="update" parameterType="com.sky.logistics.entity.LogisticsUser">
        UPDATE users
        SET
            password_hash = #{passwordHash},
            name = #{name},
            role = #{role},
            phone = #{phone},
            updated_at = now()
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM users
        WHERE id = #{id}
    </delete>

</mapper>
